{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.AspNetCore.Authentication": "Information",
        "System": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnectionString": "#{DEFAULTCONNECTIONSTRING}",
    "LogConnectionString": "#{LOGCONNECTIONSTRING}",
    "QuizTowerIdentityDbConnectionString": "#{QUIZTOWERIDENTITYDBCONNECTIONSTRING}",
    "IdentityServerDBConnectionString": "#{IDENTITYSERVERDBCONNECTIONSTRING}"
  },
  "EnableSwagger": "#{ENABLE_SWAGGERCLIENTS}"
}
